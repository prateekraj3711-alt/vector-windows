{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vector",
  "version": "0.3.4",
  "identifier": "dev.vector.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vector",
        "width": 1100,
        "height": 720,
        "decorations": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI2NDBEREFBMjYwNjM3NDIKUldSQ053WW1xdDFBdG10SStteW85TkpNZkh1cS9ZUXBNYzRraVZhSjZYc0VDVk1hTlR0dmpRbXEK",
      "endpoints": [
        "https://github.com/prateekraj3711-alt/vector-windows/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
