{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vector",
  "version": "0.2.2",
  "identifier": "dev.vector.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vector",
        "width": 1100,
        "height": 720,
        "decorations": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM4NjIyNkUyQUIyMUQyNzUKUldSMTBpR3I0aVppT0VQZzEwcHQvUitCSlhzUUVJZ3pBVUJhTU1HV1VlR096Y0hGYXlPdTIxRmsK",
      "endpoints": [
        "https://github.com/avram19/vector/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
